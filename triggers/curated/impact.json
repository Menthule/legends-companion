{
  "name": "Curated impact triggers",
  "triggers": [
    {
      "id": "impact/watched-item-looted",
      "name": "Watched item looted",
      "event": "watched-loot",
      "pattern": "",
      "enabled": true,
      "default_enabled": true,
      "source": "curated",
      "category": "Impact/Loot",
      "comments": "Fires after a System/Event Sources trigger observes loot and the item matches this character's watch list. Raw log grammar and capture mapping remain editable trigger data. Available fields are ${item}, ${quantity}, ${appliedQuantity}, ${corpse}, ${remaining}, ${quests}, and ${completed}.",
      "actions": [
        {
          "Overlay": {
            "overlay": "impact",
            "fields": {
              "headline": "YOU LOOTED",
              "big": "${item}",
              "sub": "${quests}"
            },
            "config": {
              "style": "loot-chest",
              "color": "#f2c14e",
              "intensity": "high",
              "durationMs": 4000
            }
          }
        },
        {
          "PlaySound": {
            "path": "success.wav"
          }
        }
      ]
    },
    {
      "id": "impact/watched-mob-killed",
      "name": "Watched mob killed",
      "event": "watched-kill",
      "pattern": "",
      "enabled": true,
      "default_enabled": true,
      "source": "curated",
      "category": "Impact/Kills",
      "comments": "Fires after a System/Event Sources trigger observes a death and the mob matches this character's kill watch list. The parser never sends directly to an overlay. Available fields are ${mob}, ${killer}, ${appliedQuantity}, ${remaining}, ${quests}, and ${completed}.",
      "actions": [
        {
          "Overlay": {
            "overlay": "impact",
            "fields": {
              "headline": "RIP",
              "big": "${mob}",
              "sub": "${remaining} remaining"
            },
            "config": {
              "style": "monster-rip",
              "color": "#c9d1d9",
              "durationMs": 4000
            }
          }
        },
        {
          "PlaySound": {
            "path": "death.wav"
          }
        }
      ]
    },
    {
      "id": "impact/rare-kill",
      "name": "Confirmed rare creature killed",
      "event": "rare-kill",
      "pattern": "",
      "enabled": true,
      "default_enabled": true,
      "source": "curated",
      "category": "Impact/Kills",
      "comments": "Fires only when the parser first observed the game's authoritative rare-creature Consider marker for this mob. Available fields: ${mob}, ${killer}.",
      "actions": [
        {
          "Overlay": {
            "overlay": "impact",
            "fields": {
              "headline": "RARE DEFEATED",
              "big": "${mob}",
              "sub": "Killing blow: ${killer}",
              "glyph": "★"
            },
            "config": {
              "style": "monster-rip",
              "color": "#c9a7ff",
              "intensity": "high",
              "durationMs": 4500
            }
          }
        },
        {
          "PlaySound": { "path": "success.wav" }
        }
      ]
    },
    {
      "id": "impact/finishing-blow",
      "name": "Finishing Blow",
      "pattern": "^You \\S+ (.+?) for (\\d+)(?: points? of damage)?\\.? \\(Finishing Blow\\)",
      "enabled": true,
      "default_enabled": true,
      "source": "curated",
      "category": "Highlights/Special Hits",
      "comments": "Frequent signature proc routed to the compact Highlights feed; named/record moments retain the large Impact channel.",
      "actions": [
        {
          "Overlay": {
            "overlay": "highlights",
            "fields": {
              "text": "Finishing Blow",
              "value": "${2}",
              "detail": "${1}"
            },
            "config": {
              "color": "#ffd166"
            }
          }
        }
      ]
    },
    {
      "id": "impact/slay-undead",
      "name": "Slay Undead",
      "pattern": "^You \\S+ (.+?) for (\\d+) points? of damage\\. \\(Slay Undead\\)$",
      "enabled": true,
      "default_enabled": true,
      "source": "curated",
      "category": "Highlights/Special Hits",
      "comments": "Frequent signature proc routed to Highlights; this stays trigger-owned and configurable.",
      "actions": [
        {
          "Overlay": {
            "overlay": "highlights",
            "fields": {
              "text": "Slay Undead",
              "value": "${2}",
              "detail": "${1}"
            },
            "config": {
              "color": "#ffe08a"
            }
          }
        }
      ]
    },
    {
      "id": "impact/crippling-blow",
      "name": "Crippling Blow",
      "pattern": "^You \\S+ (.+?) for (\\d+) points? of damage\\. \\(Crippling Blow\\)$",
      "enabled": true,
      "default_enabled": true,
      "source": "curated",
      "category": "Impact",
      "comments": "Rare signature hit (about once per two combat hours in the reference log), so it earns the full Impact treatment.",
      "actions": [
        {
          "Overlay": {
            "overlay": "impact",
            "fields": {
              "headline": "CRIPPLING BLOW",
              "big": "${2}",
              "sub": "${1}",
              "glyph": "✦"
            },
            "config": {
              "style": "medal",
              "color": "#ff8d8d",
              "intensity": "high"
            }
          }
        }
      ]
    },
    {
      "id": "impact/level-up",
      "name": "Level up",
      "pattern": "^You have gained a level! Welcome to level (\\d+)!$",
      "enabled": true,
      "default_enabled": true,
      "source": "curated",
      "category": "Impact",
      "comments": "Ding! Verified in Legends log: 'You have gained a level! Welcome to level 16!'. ${1}=new level. Rare, celebratory — default ON.",
      "actions": [
        {
          "Overlay": {
            "overlay": "impact",
            "fields": {
              "headline": "LEVEL UP",
              "big": "${1}",
              "sub": "Ding!"
            },
            "config": {
              "style": "level",
              "color": "#7ac74f"
            }
          }
        }
      ]
    },
    {
      "id": "impact/aa-ability-unlocked",
      "name": "AA ability unlocked",
      "pattern": "^You have (?:gained the ability \\\"(.+?)\\\"|improved (.+?)) at a cost of (\\d+) ability points?\\.$",
      "enabled": true,
      "default_enabled": true,
      "source": "curated",
      "category": "Impact/Progress",
      "comments": "An ability purchase is a durable build milestone; ordinary AA point gains stay in Highlights.",
      "actions": [
        {
          "Overlay": {
            "overlay": "impact",
            "fields": {
              "headline": "ABILITY UNLOCKED",
              "big": "${1}${2}",
              "sub": "${3} ability points",
              "glyph": "✦"
            },
            "config": {
              "style": "medal",
              "color": "#c9a7ff",
              "intensity": "high"
            }
          }
        }
      ]
    },
    {
      "id": "impact/achievement",
      "name": "Achievement completed",
      "event": "achievement-self",
      "pattern": "",
      "enabled": true,
      "default_enabled": true,
      "source": "curated",
      "category": "Impact",
      "comments": "Your typed achievement events get an animated seal moment. Available fields are ${achievement} and ${player}. Rare (~6 per career in the audit log), so default ON with sound.",
      "actions": [
        {
          "Overlay": {
            "overlay": "impact",
            "fields": {
              "headline": "ACHIEVEMENT UNLOCKED",
              "big": "${achievement}",
              "glyph": "★"
            },
            "config": {
              "style": "achievement-seal",
              "color": "#f2c14e",
              "intensity": "high",
              "durationMs": 4500
            }
          }
        },
        {
          "PlaySound": {
            "path": "success.wav"
          }
        }
      ]
    },
    {
      "id": "impact/achievement-other",
      "name": "Achievement completed (other player)",
      "event": "achievement-other",
      "pattern": "",
      "enabled": true,
      "default_enabled": false,
      "source": "curated",
      "category": "Impact",
      "comments": "A nearby player's typed achievement event gets a quieter seal moment. Available fields are ${achievement} and ${player}. The event can represent ANY player in range, so this is default OFF.",
      "actions": [
        {
          "Overlay": {
            "overlay": "impact",
            "fields": {
              "headline": "ACHIEVEMENT",
              "big": "${achievement}",
              "sub": "${player}",
              "glyph": "★"
            },
            "config": {
              "style": "achievement-seal",
              "color": "#c9d1d9",
              "intensity": "medium",
              "durationMs": 3000
            }
          }
        }
      ]
    },
    {
      "id": "impact/big-crit",
      "name": "Big crit",
      "pattern": "^You \\S+ (.+?) for (\\d{3,}) points? of damage\\. \\(Critical\\)$",
      "enabled": false,
      "default_enabled": false,
      "source": "curated",
      "category": "Highlights/Optional",
      "comments": "Optional fixed-threshold critical card. Session-record highlights are smarter by default; enable this only if a numeric threshold is useful for your level.",
      "actions": [
        {
          "Overlay": {
            "overlay": "highlights",
            "fields": {
              "text": "Critical",
              "value": "${2}",
              "detail": "${1}"
            },
            "config": {
              "color": "#ffb454"
            }
          }
        }
      ]
    }
  ]
}
