    {
      "id": "universal/survival/ally-slain",
      "name": "Player slain nearby",
      "pattern": "^([A-Z][a-z]+) has been slain by (.+)!",
      "enabled": true,
      "default_enabled": true,
      "source": "curated",
      "case_insensitive": false,
      "category": "Universal/Survival",
      "comments": "Groupmate/pet death awareness (research: exclude own kills — those use 'You have slain X!'). Case-sensitive single capitalized word so mob kills ('An orc raider has been slain by Kreira!', 'Baron Telyx V`Zher has been slain by...') don't flood the overlay: of 226 slain-by lines in the Legends log only the 4 real player/pet deaths match.",
      "actions": [
        { "DisplayText": { "template": "${1} slain by ${2}" } }
      ]
    },
    {
      "id": "universal/survival/invis-dropping",
